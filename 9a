const express = require('express');
const app = express();

app.set('view engine', 'ejs');

app.get('/', (req, res) => {
    res.render('home', { name: "Dhanushya" });
});

app.listen(3000, () => console.log("Server running"));



<!DOCTYPE html>
<html>
<body>
    <h1>Welcome <%= name %></h1>
</body>
</html>
